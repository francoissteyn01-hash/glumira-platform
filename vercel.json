{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/trpc/(.*)", "destination": "/trpc/$1" },
    { "source": "/health",   "destination": "/health" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "functions": {
    "server/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
