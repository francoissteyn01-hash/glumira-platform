{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "CommonJS",
    "moduleResolution":  "node",
    "lib":               ["ES2022"],
    "strict":            true,
    "esModuleInterop":   true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "outDir":            "dist/server",
    "rootDir":           "."
  },
  "include": ["server/**/*", "drizzle/schema.ts", "glumira-trpc-types.ts"],
  "exclude": ["node_modules", "dist", "src", "App.tsx", "main.tsx", "**/__tests__/**", "**/*.test.ts", "**/desktop.ini", "**/*.ini"]
}
