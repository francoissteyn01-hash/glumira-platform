{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "lib":              ["ES2022"],
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule":true,
    "outDir":           "dist/server",
    "rootDir":          "server"
  },
  "include": ["server"],
  "exclude": ["node_modules", "dist", "client"]
}
