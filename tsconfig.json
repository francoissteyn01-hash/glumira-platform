{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "jsx":              "react-jsx",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "resolveJsonModule":true,
    "outDir":           "dist/client",
    "rootDir":          "client/src",
    "baseUrl":          ".",
    "paths": {
      "@/*": ["client/src/*"]
    }
  },
  "include": ["client/src"],
  "exclude": ["node_modules", "dist", "server"]
}
