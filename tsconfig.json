{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ES2022", "DOM", "DOM.Iterable"],
    "jsx":               "react-jsx",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "baseUrl":           ".",
    "paths": { "@/*": ["src/*"] }
  },
  "include": ["src", "App.tsx", "main.tsx"],
  "exclude": ["node_modules", "dist", "server"]
}
